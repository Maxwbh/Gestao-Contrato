# =============================================================================
# VARIÁVEIS DE AMBIENTE — Gestão de Contratos
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
#
# REGRA: O .env contém APENAS parâmetros de infraestrutura (imutáveis).
# Parâmetros operacionais (e-mail, Twilio, notificações, BRCobrança, etc.)
# são gerenciados em: Admin → Gestão Principal → Parâmetros do Sistema
# =============================================================================

# ── Django — Core ─────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# ── Banco de Dados — Supabase PostgreSQL ──────────────────────────────────────
# 1. Acesse https://supabase.com → Settings → Database → Connection string → URI
# 2. Substitua [YOUR-PASSWORD] pela senha do projeto
# IMPORTANTE: Se a senha contiver !@#$%, faça URL-encode: ! = %21, @ = %40 etc.
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Supabase API (para funcionalidades adicionais via cliente Python)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Monitoramento ─────────────────────────────────────────────────────────────
# Sentry DSN — deixe em branco para desativar
SENTRY_DSN=

# ── HTTPS / Produção ──────────────────────────────────────────────────────────
# Necessário atrás de proxy reverso (Render, Heroku etc.) com DEBUG=False
CSRF_TRUSTED_ORIGINS=https://*.onrender.com

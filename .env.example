# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com

# =============================================================================
# DATABASE - SUPABASE POSTGRESQL
# =============================================================================
# Usando Supabase como banco de dados PostgreSQL
# Vantagens: Plano gratuito generoso, sem expiração de 90 dias
#
# Para configurar:
# 1. Acesse https://supabase.com e crie um projeto
# 2. Vá em Settings > Database > Connection string > URI
# 3. Copie a connection string e substitua [YOUR-PASSWORD] pela senha do projeto
#
# IMPORTANTE: Se a senha contiver caracteres especiais (!@#$%), faça URL-encode:
#   ! = %21, @ = %40, # = %23, $ = %24, % = %25
#
# Exemplo: senha "abc!@#" vira "abc%21%40%23"
DATABASE_URL=postgresql://postgres:YOUR-PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres

# Supabase API (opcional - para funcionalidades adicionais)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# Redis (para Celery)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# MODO DE TESTE — Safeguard para ambiente de desenvolvimento
# Quando TEST_MODE=True, TODOS os e-mails e SMS/WhatsApp são redirecionados
# para os endereços abaixo. Nunca ativar em produção.
# =============================================================================
TEST_MODE=False
TEST_RECIPIENT_EMAIL=receber@exemplo.com.br
TEST_RECIPIENT_PHONE=+5511999999999

# Email Configuration
# Para Zoho: EMAIL_HOST=smtp.zoho.com, EMAIL_PORT=465, EMAIL_USE_SSL=True, EMAIL_USE_TLS=False
# Para Gmail: EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587, EMAIL_USE_TLS=True
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=your-email@seu-dominio.com.br
EMAIL_HOST_PASSWORD=your-password
DEFAULT_FROM_EMAIL=your-email@seu-dominio.com.br

# Twilio (SMS e WhatsApp)
# Cadastre-se em: https://www.twilio.com
TWILIO_ACCOUNT_SID=your-account-sid
TWILIO_AUTH_TOKEN=your-auth-token
# Número para SMS (qualquer Twilio number com SMS capability)
TWILIO_PHONE_NUMBER=+15551234567
# Número para WhatsApp — IMPORTANTE:
#   DEV/TESTE: use o sandbox Twilio → whatsapp:+14155238886
#              (cada destinatário precisa enviar "join <sandbox-keyword>" primeiro)
#   PRODUÇÃO:  registre seu número em console.twilio.com → Messaging → Senders → WhatsApp Senders
#              Números SMS comuns NÃO funcionam como WhatsApp sender (erro Twilio 63007)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Notificações
NOTIFICACAO_DIAS_ANTECEDENCIA=5
# Twilio trial insere "Sent from your Twilio trial account - " (38 chars) em todo SMS.
# True = trunca o corpo para que total (prefixo + corpo) não ultrapasse 250 chars.
# False = sem truncagem (conta produção sem prefixo trial).
TWILIO_TRIAL_MODE=False

# =============================================================================
# RENDER FREE TIER - Tarefas Agendadas
# =============================================================================
# Token para autenticação da API de tarefas (alternativa ao Celery)
# Gere um token seguro: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Configure um cron job em https://cron-job.org para chamar /api/tasks/run-all/
TASK_TOKEN=seu-token-seguro-aqui

# =============================================================================
# RENDER FREE TIER - Tarefas Agendadas
# =============================================================================
# Token para autenticação da API de tarefas (alternativa ao Celery)
# Gere um token seguro: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Configure um cron job em https://cron-job.org para chamar /api/tasks/run-all/
TASK_TOKEN=seu-token-seguro-aqui

# Sentry (opcional - monitoramento de erros)
SENTRY_DSN=

# =============================================================================
# BRCOBRANÇA - Geração de Boletos Bancários
# =============================================================================
# API BRCobrança para geração de boletos. Execute com Docker:
# docker run -p 9292:9292 kivanio/brcobranca
# Documentação: https://github.com/kivanio/brcobranca
BRCOBRANCA_URL=http://localhost:9292
BRCOBRANCA_TIMEOUT=30

# Configurações de APIs
# Banco Central do Brasil - Séries Temporais
BCBAPI_URL=https://api.bcb.gov.br/dados/serie/bcdata.sgs.{}/dados
IPCA_SERIE_ID=433
IGPM_SERIE_ID=189
SELIC_SERIE_ID=432

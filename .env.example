# =============================================================================
# VARIÁVEIS DE AMBIENTE — Gestão de Contratos
# =============================================================================
# Copie este arquivo para .env e preencha os valores.
#
# ARQUITETURA DE CONFIGURAÇÃO (2 camadas):
#   Camada 1 — Infraestrutura (este arquivo): lidas diretamente pelo settings.py
#   Camada 2 — Operacional (banco de dados): email, Twilio, WhatsApp, etc.
#              Sincronize com: python manage.py sync_params_from_env
#              Edite em: Admin → Gestão Principal → Parâmetros do Sistema
# =============================================================================

# ── Django — Core ─────────────────────────────────────────────────────────────
SECRET_KEY=your-secret-key-here-min-50-chars
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,.onrender.com
CSRF_TRUSTED_ORIGINS=https://*.onrender.com
# Cifra de credenciais de banco / token bapi_ (Boleto-API). Chave Fernet:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Se vazio, deriva do SECRET_KEY (ok em dev; defina em produção).
CREDENTIALS_ENCRYPTION_KEY=

# ── Banco de Dados — Supabase PostgreSQL ──────────────────────────────────────
# Usar porta 6543 (pgBouncer) para Render Free Tier
# URL-encode senha: ! = %21, @ = %40, # = %23, $ = %24
DATABASE_URL=postgresql://postgres.PROJECT_ID:SENHA_URL_ENCODED@aws-0-us-east-2.pooler.supabase.com:6543/postgres

# Supabase client Python (opcional — funcionalidades extras)
SUPABASE_URL=https://PROJECT_ID.supabase.co
SUPABASE_KEY=sb_publishable_XXXXXXXXXXXXXXXXXXXXXXXX

# ── Redis / Celery ────────────────────────────────────────────────────────────
# No Render: injetado automaticamente via fromService
REDIS_URL=redis://localhost:6379/0

# ── Monitoramento de Erros ────────────────────────────────────────────────────
SENTRY_DSN=

# ── URL Pública do Sistema ────────────────────────────────────────────────────
SITE_URL=https://seu-app.onrender.com

# ── Boleto-API Gateway (cobrança registrada C6/Sicoob) ────────────────────────
# URL do gateway stateless; as credenciais do banco ficam cifradas no sistema
# (CREDENTIALS_ENCRYPTION_KEY) e são enviadas via Bearer bapi_.
BOLETO_API_URL=http://localhost:8001
BOLETO_API_TIMEOUT=30
BOLETO_API_MAX_TENTATIVAS=3
BOLETO_API_DELAY_INICIAL=2

# ── Webhooks de Cobrança — OBRIGATÓRIOS EM PRODUÇÃO ───────────────────────────
# Os dois webhooks dão BAIXA em parcelas. Fail-closed: com DEBUG=False e a
# chave vazia, o endpoint responde 503 (não aceita POST anônimo).
# Segredo HMAC do webhook do Boleto-API (X-Signature: sha256=...):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
EVENT_WEBHOOK_SECRET=
# Token Bearer do webhook PIX do PSP:
PIX_WEBHOOK_TOKEN=

# ── API de BI (Power BI / Looker / Metabase) ──────────────────────────────────
# Token Bearer de /financeiro/api/relatorios/posicao/ (fail-closed: vazio ⇒ 503)
BI_API_TOKEN=

# ── Relatórios agendados (destinatários) ──────────────────────────────────────
RELATORIO_INADIMPLENCIA_EMAILS=
RELATORIO_POSICAO_EMAILS=

# ── Web Push — Portal do Comprador (VAPID) ────────────────────────────────────
# Gerar par: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key, v.private_key)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_EMAIL=admin@example.com

# =============================================================================
# PARÂMETROS OPERACIONAIS (Camada 2)
# Lidos por: python manage.py sync_params_from_env → gravados em ParametroSistema
# Após sync, editáveis via Admin sem novo deploy.
# =============================================================================

# ── Modo de Teste ─────────────────────────────────────────────────────────────
# True  = ambiente de teste/homologação (todos envios vão para TEST_RECIPIENT_*)
# False = produção (envios reais para os destinatários dos contratos)
TEST_MODE=True
TEST_RECIPIENT_EMAIL=teste@seudominio.com.br
TEST_RECIPIENT_PHONE=+5531900000000

# ── E-mail SMTP ───────────────────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.zoho.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=seu-email@seudominio.com.br
EMAIL_HOST_PASSWORD=sua-senha-de-aplicativo
DEFAULT_FROM_EMAIL=seu-email@seudominio.com.br
EMAIL_TIMEOUT=10

# ── Bounce Monitoring — IMAP ──────────────────────────────────────────────────
BOUNCE_EMAIL_ADDRESS=bounces@seudominio.com.br
BOUNCE_IMAP_HOST=imap.zoho.com
BOUNCE_IMAP_PORT=993
BOUNCE_IMAP_USER=bounces@seudominio.com.br
BOUNCE_IMAP_PASSWORD=senha-imap-bounces
BOUNCE_IMAP_FOLDER=INBOX

# ── Twilio — SMS e WhatsApp ───────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+15550000000
TWILIO_WHATSAPP_NUMBER=whatsapp:+15550000000
TWILIO_STATUS_CALLBACK_URL=https://seu-app.onrender.com/notificacoes/webhook/twilio/

# ── Notificações ──────────────────────────────────────────────────────────────
NOTIFICACAO_DIAS_ANTECEDENCIA=5
NOTIFICACAO_DIAS_INADIMPLENCIA=3

# ── Tarefas Agendadas ─────────────────────────────────────────────────────────
TASK_TOKEN=token-secreto-minimo-32-chars

# ── BRCobrança (Geração de Boletos) ──────────────────────────────────────────
BRCOBRANCA_URL=https://sua-brcobranca.onrender.com
BRCOBRANCA_TIMEOUT=30
BRCOBRANCA_MAX_TENTATIVAS=3
BRCOBRANCA_DELAY_INICIAL=2
# Ajuste fino (defaults sensatos — altere só se necessário):
# BRCOBRANCA_DELAY_MAX_429=8            # teto do backoff em 429 (s)
# BRCOBRANCA_HEALTH_TIMEOUT=90          # timeout do health-check (s)
# BRCOBRANCA_INTER_BOLETO_DELAY_MS=100  # pausa entre boletos em lote (ms)
# BRCOBRANCA_REMESSA_COOLDOWN_S=5       # intervalo mínimo entre remessas (s)
# BRCOBRANCA_TEMPO_API_BOLETO_S=1.8     # estimativa p/ barra de progresso (s)
# BRCOBRANCA_TEMPLATE=prawn             # template de PDF do BRCobrança

# ── Portal do Comprador ───────────────────────────────────────────────────────
PORTAL_EMAIL_VERIFICACAO=False

# ── Índices Econômicos — BCB (defaults públicos) ──────────────────────────────
BCBAPI_URL=https://api.bcb.gov.br/dados/serie/bcdata.sgs.{}/dados
IPCA_SERIE_ID=433
IGPM_SERIE_ID=189
SELIC_SERIE_ID=432

# =============================================================================
# PROVEDORES WHATSAPP (configurados via Admin → Notificações → WhatsApp)
# Não são env vars — ficam em ConfiguracaoWhatsApp no banco de dados.
# =============================================================================
#
# Evolution API (Baileys):
#   api_url = https://sua-evolution-api.onrender.com
#   api_key = AUTHENTICATION_API_KEY (painel Render)
#   instancia = sua-instancia
#   Webhook: /notificacoes/webhook/evolution/
#
# BSP Brasileiro (Hablla / Poli Digital / Digisac) — W-07:
#   api_url         = https://app.hablla.com
#   api_key         = Bearer token do BSP
#   phone_number_id = ID do número no Meta Business
#   Webhook: /notificacoes/webhook/bsp/
#   hub.verify_token = api_key (mesmo valor)
#
# Z-API:
#   api_url = https://api.z-api.io
#   api_key = token da instância
#   instancia = instance ID
#   client_token = Client-Token header


# =============================================================================
# IA — CHAVES DE API (env-only; NÃO são sincronizadas para o banco)
# Consumidores: chatbot humanizado (H-02), importação de contratos por PDF,
# workflows de IA. Governança fica no banco (Admin → Parâmetros do Sistema):
# CHATBOT_IA_ATIVO (kill-switch), CHATBOT_MODELO, limites em LimiteUsoIA.
# =============================================================================

# ─── IA — Anthropic / Claude ──────────────────────────────────────────────────
# Obrigatória para: chatbot com IA, importação de PDF (tiers Claude), workflows.
# Sem ela: chatbot cai no despachante de regras; importação exige preenchimento
# manual. Obter em: https://console.anthropic.com
ANTHROPIC_API_KEY=

# ─── IA — Google Gemini (Tier 0 gratuito) ─────────────────────────────────────
# Opcional. Sem esta chave o sistema usa apenas a cadeia Claude normalmente.
# Gratuito: 1.500 req/dia · 15 RPM · modelo: gemini-2.0-flash
# Obter em: https://aistudio.google.com/apikey
GEMINI_API_KEY=

[run]
source = .
omit =
    */migrations/*
    */tests/*
    */test_*
    manage.py
    gestao_contrato/wsgi.py
    gestao_contrato/asgi.py
    oracle_migration/*
    venv/*
    .venv/*
    */node_modules/*
    htmlcov/*

[report]
fail_under = 80
show_missing = True
skip_covered = False
precision = 2
exclude_lines =
    pragma: no cover
    def __repr__
    if self.debug:
    if settings.DEBUG
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    class .*\bProtocol\):
    @(abc\.)?abstractmethod

[html]
directory = htmlcov
title = Gestao-Contrato Coverage Report
